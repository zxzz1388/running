function animateStats(){
  var els = [
    {id:'s1', val:11, suffix:'+'},
    {id:'s2', val:1000, suffix:'+'},
    {id:'s3', val:75, suffix:'%'},
    {id:'s4', val:10, suffix:'+'}
  ];
  var band = document.querySelector('.stats-band');
  if(!band) return;
  var obs = new IntersectionObserver(function(entries){
    if(entries[0].isIntersecting){
      els.forEach(function(item){
        var el = document.getElementById(item.id);
        if(!el) return;
        var start=0, step=Math.ceil(item.val/50);
        var t=setInterval(function(){
          start=Math.min(start+step,item.val);
          el.textContent=start+item.suffix;
          if(start>=item.val)clearInterval(t);
        },25);
      });
      obs.disconnect();
    }
  },{threshold:0.3});
  obs.observe(band);
}

