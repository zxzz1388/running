<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Bimbel Attin Indonesia</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --red:#c8102e;--red2:#e8192e;
  --gold:#d4a017;--gold2:#f0c040;
  --dark:#0a0a0e;--dark2:#111116;--dark3:#1a1a22;
  --txt:#f0f0f8;--txt2:#a0a0b8;--txt3:#606070;
  --bdr:rgba(255,255,255,.06);--bdr2:rgba(255,255,255,.12);
}
html{scroll-behavior:smooth}
body{background:var(--dark);color:var(--txt);font-family:'Segoe UI',system-ui,sans-serif;overflow-x:hidden}

/* ── PARALLAX HERO ─────────────────────────────── */
.parallax-hero{
  position:relative;min-height:100vh;
  display:flex;align-items:center;overflow:hidden;
}
.p-layer{
  position:absolute;inset:0;
  background-attachment:fixed;
  background-size:cover;background-position:center;
}
.p-layer-1{
  background:radial-gradient(ellipse 120% 80% at 80% 40%,
    rgba(200,16,46,.25) 0%,rgba(200,16,46,.05) 40%,transparent 70%);
}
.p-layer-2{
  background:radial-gradient(ellipse 60% 60% at 20% 60%,
    rgba(14,165,233,.08) 0%,transparent 60%);
}
.p-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,.022) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.022) 1px,transparent 1px);
  background-size:80px 80px;
  transform:perspective(500px) rotateX(12deg) scale(1.3);
  transform-origin:center bottom;
  animation:gridDrift 20s linear infinite;
}
@keyframes gridDrift{from{background-position:0 0}to{background-position:80px 80px}}

.p-orbs{position:absolute;inset:0;pointer-events:none}
.orb{
  position:absolute;border-radius:50%;
  filter:blur(60px);
  animation:orbFloat var(--d,8s) ease-in-out infinite;
}
.orb1{width:400px;height:400px;top:-10%;right:-5%;
  background:radial-gradient(circle,rgba(200,16,46,.18),transparent 70%);
  --d:9s}
.orb2{width:300px;height:300px;bottom:10%;left:-5%;
  background:radial-gradient(circle,rgba(212,160,23,.12),transparent 70%);
  --d:11s;animation-delay:-3s}
.orb3{width:200px;height:200px;top:30%;left:40%;
  background:radial-gradient(circle,rgba(14,165,233,.08),transparent 70%);
  --d:7s;animation-delay:-5s}
@keyframes orbFloat{
  0%,100%{transform:translateY(0) scale(1)}
  50%{transform:translateY(-30px) scale(1.05)}
}

.hero-content{
  position:relative;z-index:10;
  max-width:1140px;margin:0 auto;padding:0 32px;
  width:100%;
}
.hero-grid-layout{
  display:grid;grid-template-columns:1fr 400px;
  gap:80px;align-items:center;
}
.hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(200,16,46,.12);border:1px solid rgba(200,16,46,.3);
  border-radius:50px;padding:6px 16px;
  font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;
  color:rgba(200,16,46,.9);margin-bottom:24px;
}
.hero-badge::before{content:"";width:6px;height:6px;background:var(--red);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.5)}}
.hero-h1{
  font-size:clamp(42px,6vw,80px);font-weight:900;line-height:1.02;
  color:#fff;margin-bottom:24px;letter-spacing:-2px;
}
.hero-h1 .gr{
  background:linear-gradient(135deg,#c8102e 0%,#ff4d6d 40%,#d4a017 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-desc{
  font-size:18px;color:var(--txt2);line-height:1.8;
  margin-bottom:40px;max-width:560px;
}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:48px}
.btn-hero{
  display:inline-flex;align-items:center;gap:8px;
  padding:15px 32px;border-radius:14px;
  font-family:inherit;font-weight:700;font-size:15px;cursor:pointer;
  border:none;transition:all .3s;text-decoration:none;
}
.btn-red{background:linear-gradient(135deg,#c8102e,#e8192e);color:#fff}
.btn-red:hover{transform:translateY(-3px);box-shadow:0 16px 40px rgba(200,16,46,.4)}
.btn-out{background:rgba(255,255,255,.06);border:1px solid var(--bdr2);color:var(--txt)}
.btn-out:hover{background:rgba(255,255,255,.1);transform:translateY(-3px)}
.hero-tags{display:flex;gap:10px;flex-wrap:wrap}
.htag{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(255,255,255,.05);border:1px solid var(--bdr2);
  border-radius:8px;padding:7px 13px;font-size:12px;color:var(--txt2);font-weight:500;
}
.htag .dot{width:6px;height:6px;border-radius:50%}

/* Hero Visual Card */
.hero-visual{position:relative}
.vis-card{
  background:linear-gradient(135deg,rgba(255,255,255,.06),rgba(255,255,255,.02));
  border:1px solid rgba(255,255,255,.1);border-radius:24px;
  padding:32px;backdrop-filter:blur(20px);
  box-shadow:0 32px 80px rgba(0,0,0,.5);
  animation:cardFloat 6s ease-in-out infinite;
}
@keyframes cardFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.vis-logo{
  width:80px;height:80px;
  background:linear-gradient(135deg,#c8102e,#e8192e);
  border-radius:20px;display:flex;align-items:center;justify-content:center;
  font-size:40px;margin-bottom:20px;
  box-shadow:0 8px 32px rgba(200,16,46,.4);
}
.vis-title{font-size:22px;font-weight:800;color:#fff;margin-bottom:4px}
.vis-sub{font-size:13px;color:var(--txt2);margin-bottom:24px}
.vis-stats{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.vstat{
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);
  border-radius:14px;padding:16px;
}
.vstat-num{font-size:28px;font-weight:900;background:linear-gradient(135deg,#c8102e,#d4a017);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.vstat-lbl{font-size:11px;color:var(--txt3);margin-top:4px;text-transform:uppercase;letter-spacing:.5px}
.vis-progress{margin-top:20px}
.vp-label{display:flex;justify-content:space-between;font-size:12px;color:var(--txt2);margin-bottom:6px}
.vp-bar{height:6px;background:rgba(255,255,255,.08);border-radius:6px;overflow:hidden}
.vp-fill{height:100%;background:linear-gradient(90deg,#c8102e,#d4a017);border-radius:6px;transition:width 1.5s ease}
.vis-badge{
  position:absolute;top:-16px;right:-16px;
  background:linear-gradient(135deg,#d4a017,#f0c040);
  border-radius:50%;width:64px;height:64px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-weight:900;font-size:18px;color:#000;
  box-shadow:0 8px 24px rgba(212,160,23,.4);
  animation:spin-slow 8s linear infinite;
}
@keyframes spin-slow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

/* ── SCROLL INDICATOR ──────────────────────────── */
.scroll-ind{
  position:absolute;bottom:40px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  z-index:10;cursor:pointer;
}
.scroll-ind span{font-size:11px;color:var(--txt3);text-transform:uppercase;letter-spacing:2px}
.scroll-mouse{
  width:26px;height:40px;border:2px solid rgba(255,255,255,.2);
  border-radius:13px;position:relative;
}
.scroll-dot{
  position:absolute;top:6px;left:50%;transform:translateX(-50%);
  width:4px;height:8px;background:var(--red);border-radius:2px;
  animation:scrollAnim 2s infinite;
}
@keyframes scrollAnim{0%{top:6px;opacity:1}100%{top:20px;opacity:0}}

/* ── NAV ────────────────────────────────────────── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:999;
  padding:0 40px;height:70px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(10,10,14,.0);backdrop-filter:blur(0px);
  transition:all .4s;
}
nav.scrolled{
  background:rgba(10,10,14,.92);backdrop-filter:blur(24px);
  border-bottom:1px solid var(--bdr);
}
.nav-brand{display:flex;align-items:center;gap:12px;text-decoration:none}
.nav-logo{width:40px;height:40px;background:linear-gradient(135deg,#c8102e,#e8192e);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px}
.nav-name{font-weight:800;font-size:17px;color:#fff}
.nav-links{display:flex;gap:4px;align-items:center}
.nav-link{padding:8px 14px;border-radius:9px;font-size:13px;font-weight:500;color:var(--txt2);cursor:pointer;border:none;background:transparent;font-family:inherit;transition:all .2s;white-space:nowrap}
.nav-link:hover,.nav-link.active{color:#fff;background:rgba(255,255,255,.07)}
.nav-cta{background:linear-gradient(135deg,#c8102e,#e8192e);color:#fff;border:none;border-radius:10px;padding:9px 20px;font-family:inherit;font-weight:700;font-size:13px;cursor:pointer;transition:all .25s}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(200,16,46,.4)}
.mob-menu{display:none;background:rgba(255,255,255,.06);border:1px solid var(--bdr2);border-radius:9px;padding:9px;cursor:pointer;color:var(--txt)}

/* ── SECTIONS ───────────────────────────────────── */
.section{padding:100px 0;position:relative}
.section.dark{background:var(--dark)}
.section.dark2{background:var(--dark2)}
.wrap{max-width:1140px;margin:0 auto;padding:0 32px}
.sec-label{
  display:inline-flex;align-items:center;gap:8px;
  font-size:11px;font-weight:700;text-transform:uppercase;
  letter-spacing:2.5px;color:var(--red);margin-bottom:16px;
}
.sec-label::before{content:"";width:28px;height:2px;background:linear-gradient(90deg,var(--red),#ff4d6d)}
.sec-h2{font-size:clamp(28px,4vw,48px);font-weight:900;color:#fff;margin-bottom:14px;letter-spacing:-1px;line-height:1.1}
.sec-desc{font-size:16px;color:var(--txt2);line-height:1.8;max-width:560px}

/* ── STATS BAND ─────────────────────────────────── */
.stats-band{
  padding:60px 0;
  background:linear-gradient(135deg,rgba(200,16,46,.08),rgba(212,160,23,.04));
  border-top:1px solid rgba(200,16,46,.15);border-bottom:1px solid rgba(200,16,46,.15);
  position:relative;overflow:hidden;
}
.stats-band::before{
  content:"";position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 100% at 50% 50%,rgba(200,16,46,.06),transparent);
}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;position:relative;z-index:1}
.stat-item{
  text-align:center;padding:32px 20px;
  border-right:1px solid rgba(255,255,255,.06);
}
.stat-item:last-child{border-right:none}
.stat-num{
  font-size:clamp(36px,5vw,56px);font-weight:900;line-height:1;
  background:linear-gradient(135deg,#fff 0%,rgba(255,255,255,.7) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.stat-num.red{background:linear-gradient(135deg,#c8102e,#ff4d6d);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.stat-num.gold{background:linear-gradient(135deg,#d4a017,#f0c040);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.stat-num.green{background:linear-gradient(135deg,#22c55e,#4ade80);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.stat-lbl{font-size:13px;color:var(--txt3);margin-top:8px;text-transform:uppercase;letter-spacing:1px}

/* ── PROGRAMS ────────────────────────────────────── */
.prog-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-top:64px}
.prog-card{
  background:linear-gradient(135deg,rgba(255,255,255,.05),rgba(255,255,255,.02));
  border:1px solid rgba(255,255,255,.08);border-radius:24px;
  padding:40px;position:relative;overflow:hidden;
  transition:all .4s;cursor:default;
}
.prog-card:hover{
  border-color:rgba(200,16,46,.3);
  transform:translateY(-8px);
  box-shadow:0 24px 60px rgba(0,0,0,.5);
}
.prog-card::before{
  content:"";position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--bar,linear-gradient(90deg,#c8102e,#ff4d6d));
}
.prog-icon{font-size:48px;margin-bottom:20px;display:block}
.prog-type{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--red);margin-bottom:12px}
.prog-name{font-size:24px;font-weight:800;color:#fff;margin-bottom:8px}
.prog-tag{font-size:13px;color:rgba(200,16,46,.8);font-weight:600;margin-bottom:16px}
.prog-desc{font-size:14px;color:var(--txt2);line-height:1.75;margin-bottom:28px}
.prog-feats{display:flex;flex-direction:column;gap:8px;margin-bottom:32px}
.prog-feat{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--txt2)}
.prog-feat::before{content:"✓";width:20px;height:20px;background:rgba(200,16,46,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--red);font-weight:700;flex-shrink:0}
.prog-meta{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding-top:24px;border-top:1px solid rgba(255,255,255,.06)}
.pm-item .pm-l{font-size:10px;color:var(--txt3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
.pm-item .pm-v{font-size:13px;color:var(--txt);font-weight:600}
.prog-glow{position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;filter:blur(60px);background:rgba(200,16,46,.12);pointer-events:none}

/* ── BRANCHES ─────────────────────────────────────── */
.branch-scroll{
  display:flex;gap:16px;
  overflow-x:auto;padding-bottom:16px;margin-top:48px;
  scroll-snap-type:x mandatory;
  scrollbar-width:thin;scrollbar-color:var(--red) transparent;
}
.branch-card{
  flex-shrink:0;width:260px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:18px;padding:24px;
  scroll-snap-align:start;transition:all .3s;
  position:relative;overflow:hidden;
}
.branch-card:hover{border-color:rgba(200,16,46,.3);transform:translateY(-4px)}
.branch-card::after{
  content:"";position:absolute;bottom:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,rgba(200,16,46,.5),transparent);
}
.bc-num{
  width:36px;height:36px;border-radius:10px;
  background:rgba(200,16,46,.12);border:1px solid rgba(200,16,46,.2);
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:13px;color:var(--red);margin-bottom:14px;
}
.bc-name{font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.bc-prov{font-size:11px;color:var(--txt3);margin-bottom:12px}
.bc-info{font-size:12px;color:var(--txt2);display:flex;align-items:center;gap:6px;margin-bottom:4px}
.bc-info::before{content:"";width:4px;height:4px;border-radius:50%;background:var(--red);flex-shrink:0}

/* ── GRADUATES ─────────────────────────────────────── */
.grad-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:64px}
.grad-card{
  border-radius:20px;overflow:hidden;position:relative;
  background:var(--dark3);
  transition:all .4s;
}
.grad-card:hover{transform:translateY(-8px);box-shadow:0 24px 60px rgba(0,0,0,.5)}
.grad-img{
  height:220px;background:linear-gradient(135deg,#1a1a2a,#2a1a2a);
  display:flex;align-items:center;justify-content:center;
  font-size:64px;position:relative;overflow:hidden;
}
.grad-img img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
.grad-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.9) 0%,transparent 50%)}
.grad-year{
  position:absolute;top:14px;right:14px;
  background:linear-gradient(135deg,#d4a017,#f0c040);
  color:#000;font-weight:800;font-size:12px;padding:4px 12px;border-radius:20px;
}
.grad-title{
  position:absolute;bottom:14px;left:16px;right:16px;
  font-size:16px;font-weight:800;color:#fff;
}
.grad-body{padding:20px}
.grad-caption{font-size:13px;color:var(--txt2);line-height:1.65;margin-bottom:18px}
.grad-row{display:flex;align-items:center;gap:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)}
.grad-count{font-size:42px;font-weight:900;line-height:1;background:linear-gradient(135deg,#d4a017,#f0c040);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.grad-ptns{flex:1;padding-left:14px;border-left:1px solid rgba(255,255,255,.06)}
.grad-ptns-l{font-size:10px;color:var(--txt3);text-transform:uppercase;margin-bottom:4px}
.grad-ptns-v{font-size:12px;font-weight:600;color:var(--txt)}

/* ── TRY OUT ───────────────────────────────────────── */
.to-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
.to-card{
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
  border-radius:18px;padding:28px;cursor:pointer;transition:all .3s;
  position:relative;overflow:hidden;
}
.to-card:hover{border-color:rgba(200,16,46,.3);transform:translateY(-6px);box-shadow:0 16px 40px rgba(0,0,0,.4)}
.to-card::before{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(200,16,46,.04),transparent);opacity:0;transition:opacity .3s}
.to-card:hover::before{opacity:1}
.to-icon{font-size:40px;margin-bottom:16px}
.to-cat{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:rgba(168,85,247,.8);margin-bottom:10px}
.to-name{font-size:17px;font-weight:700;color:#fff;margin-bottom:8px}
.to-desc{font-size:13px;color:var(--txt2);margin-bottom:20px;line-height:1.6}
.to-meta{display:flex;gap:8px;flex-wrap:wrap}
.to-tag{display:inline-flex;align-items:center;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600}
.to-tag.blue{background:rgba(59,130,246,.12);color:#60a5fa;border:1px solid rgba(59,130,246,.2)}
.to-tag.green{background:rgba(34,197,94,.1);color:#4ade80;border:1px solid rgba(34,197,94,.2)}

/* ── REGISTER SECTION ──────────────────────────────── */
.reg-wrap{
  background:linear-gradient(135deg,rgba(200,16,46,.08),rgba(212,160,23,.04));
  border:1px solid rgba(200,16,46,.15);border-radius:32px;
  padding:64px;position:relative;overflow:hidden;margin-top:64px;
}
.reg-wrap::before{content:"";position:absolute;top:-100px;right:-100px;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(200,16,46,.15),transparent 70%);pointer-events:none}
.reg-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;position:relative;z-index:1}
.reg-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.ff{grid-column:1/-1}
.inp{
  width:100%;padding:13px 16px;
  background:rgba(255,255,255,.06);
  border:1.5px solid rgba(255,255,255,.1);
  border-radius:12px;font-size:14px;
  font-family:inherit;color:#fff;outline:none;transition:all .2s;
  -webkit-appearance:none;
}
.inp:focus{border-color:rgba(200,16,46,.6);background:rgba(200,16,46,.05);box-shadow:0 0 0 3px rgba(200,16,46,.1)}
.inp::placeholder{color:rgba(255,255,255,.25)}
select.inp option{background:#1a1a22;color:#fff}
textarea.inp{resize:vertical;min-height:80px;line-height:1.6}
.lbl{display:block;font-size:11px;font-weight:700;color:rgba(255,255,255,.4);margin-bottom:6px;text-transform:uppercase;letter-spacing:.7px}
.btn-submit{
  width:100%;padding:15px;
  background:linear-gradient(135deg,#c8102e,#e8192e);
  color:#fff;border:none;border-radius:12px;
  font-family:inherit;font-weight:700;font-size:15px;cursor:pointer;
  transition:all .3s;margin-top:8px;
}
.btn-submit:hover{transform:translateY(-2px);box-shadow:0 12px 32px rgba(200,16,46,.4)}
.dok{
  display:inline-flex;align-items:center;gap:8px;
  padding:10px 16px;border-radius:10px;font-size:13px;font-weight:600;margin-top:10px;
}
.dok.ok{background:rgba(212,160,23,.1);color:#f0c040;border:1px solid rgba(212,160,23,.2)}
.dok.bad{background:rgba(200,16,46,.1);color:#ff4d6d;border:1px solid rgba(200,16,46,.2)}

/* ── TRY OUT MODAL ──────────────────────────────────── */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.85);display:none;align-items:center;justify-content:center;z-index:2000;padding:20px;backdrop-filter:blur(12px)}
.mo.open{display:flex}
.mo-box{
  width:100%;max-width:840px;max-height:90vh;overflow-y:auto;
  background:var(--dark2);border:1px solid rgba(255,255,255,.1);
  border-radius:24px;padding:40px;
