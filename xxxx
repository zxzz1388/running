function startTO(id){
  var to = DATA.tryouts.find(function(x){return x.id===id;});
  if(!to) return;
  toState = {id:id, answers:{}, timer:null, total:to.dur*60};
  document.getElementById('mo-nm').textContent = to.judul;
  document.getElementById('mo-nfo').textContent = to.questions.length+' soal \u2022 '+to.dur+' menit \u2022 '+to.cat;
  renderTOQs(to);
  document.getElementById('to-mo').classList.add('open');
  var rem = toState.total;
  document.getElementById('mo-tmr').style.color = '';
  toState.timer = setInterval(function(){
    rem--;
    if(rem===0){clearInterval(toState.timer);submitTO();return;}
    var m=Math.floor(rem/60),s=rem%60;
    var el=document.getElementById('mo-tmr');
    if(el)el.textContent=pad2(m)+':'+pad2(s);
    if(rem===60||rem===30||rem===10){if(el)el.style.color='#ff4d6d';}
  },1000);
}

