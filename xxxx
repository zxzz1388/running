function findDisc(code){
  if(!code) return null;
  return DATA.discounts.find(function(d){return d.kode===code.toUpperCase()&&d.aktif;})||null;
}
function chkD(){
  var code=document.getElementById('rdisc').value.toUpperCase();
  var nfo=document.getElementById('disc-nfo');
  if(!code){nfo.style.display='none';return;}
  var d=findDisc(code);nfo.style.display='block';
  nfo.innerHTML=d
    ?'\u003cdiv class="dok ok"\u003e\uD83C\uDF89 Kode valid! Diskon \u003cstrong\u003e'+d.pct+'%\u003c/strong\u003e \u2014 '+h(d.desc)+'\u003c/div\u003e'
    :'\u003cdiv class="dok bad"\u003e\u2717 Kode tidak valid\u003c/div\u003e';
}
function onBrChange(){
  var val=document.getElementById('rb').value;
  var nfo=document.getElementById('wa-nfo');
  if(!val){nfo.style.display='none';return;}
  var b=DATA.branches.find(function(x){return(x.nama+' - '+x.kota)===val;});
  nfo.style.display='block';
  nfo.innerHTML=b
    ?'\u003cdiv style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:10px;padding:10px 14px;font-size:13px;color:#4ade80"\u003e\uD83D\uDCF2 Notifikasi akan dikirim ke WA Admin \u003cstrong\u003e'+h(b.nama)+'\u003c/strong\u003e\u003c/div\u003e'
    :'';
}
function submitReg(){
  var nama=document.getElementById('rn').value.trim();
  var phone=document.getElementById('rp').value.trim();
  var prog=document.getElementById('rpr').value;
  var cab=document.getElementById('rb').value;
  var ee=document.getElementById('reg-err');
  if(!nama||!phone||!prog||!cab){
    ee.textContent='Harap lengkapi semua field bertanda *';ee.style.display='block';return;
  }
  ee.style.display='none';
  var disc=findDisc(document.getElementById('rdisc').value);
  var branch=DATA.branches.find(function(b){return(b.nama+' - '+b.kota)===cab;});
  document.getElementById('reg-box').style.display='none';
  document.getElementById('reg-ok').style.display='block';
  document.getElementById('disc-ok').textContent=disc?'\uD83C\uDF89 Diskon '+disc.pct+'% berhasil diterapkan!':'';
  if(branch&&branch.phone){
    var lines=[
      '*\uD83D\uDCDA PENDAFTARAN BARU - Bimbel Attin*','---',
      '*Nama* : '+nama,'*HP/WA* : '+phone,
      '*Program* : '+prog,'*Cabang* : '+branch.nama,'*Tanggal* : '+today()
    ];
    if(disc)lines.push('*Diskon* : '+disc.kode+' ('+disc.pct+'%)');
    var pm=document.getElementById('rm').value;if(pm)lines.push('*Pesan* : '+pm);
    lines.push('---','_Segera hubungi calon siswa._');
    setTimeout(function(){window.open('https://wa.me/'+branch.phone+'?text='+encodeURIComponent(lines.join('\n')),'_blank');},600);
  }
}
function resetReg(){
  document.getElementById('reg-ok').style.display='none';
  document.getElementById('reg-box').style.display='block';
  ['rn','rp','re','rs','rm','rdisc'].forEach(function(id){var e=document.getElementById(id);if(e)e.value='';});
  ['rg','rpr','rb'].forEach(function(id){document.getElementById(id).value='';});
  document.getElementById('disc-nfo').style.display='none';
  document.getElementById('wa-nfo').style.display='none';
}

