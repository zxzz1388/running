function selOpt(qi,oi){
  toState.answers[qi]=oi;
  var to=DATA.tryouts.find(function(x){return x.id===toState.id;});if(!to)return;
  for(var i=0;i!==to.questions[qi].opts.length;i++){
    var el=document.getElementById('qo-'+qi+'-'+i);
    if(el)el.className='q-opt'+(i===oi?' sel':'');
