// PARALLAX + SCROLL
// ════════════════════════════════════════════════════════════════
var ticking = false;
window.addEventListener('scroll', function(){
  if(!ticking){requestAnimationFrame(function(){
    var y = window.scrollY;
    // Nav glass effect
    document.getElementById('nav').classList.toggle('scrolled', y > 60);
    // Parallax grid
    var grid = document.getElementById('pgrid');
    if(grid) grid.style.transform = 'perspective(500px) rotateX(12deg) scale(1.3) translateY('+y*0.15+'px)';
    // Parallax orbs
    var orb1 = document.querySelector('.orb1');
    var orb2 = document.querySelector('.orb2');
    if(orb1) orb1.style.transform = 'translateY('+y*0.2+'px)';
    if(orb2) orb2.style.transform = 'translateY('+(y*-0.1)+'px)';
    ticking = false;
  });
  ticking = true;
  }
});

// ════════════════════════════════════════════════════════════════
// INTERSECTION OBSERVER — animate on scroll
// ════════════════════════════════════════════════════════════════
var io = new IntersectionObserver(function(entries){
  entries.forEach(function(e){
    if(e.isIntersecting){
      e.target.style.opacity='1';
      e.target.style.transform='translateY(0)';
      // Counter animation
      var counters = e.target.querySelectorAll('[data-count]');
      counters.forEach(animateCounter);
    }
  });
}, {threshold:0.15});

function animateCounter(el){
  var target = parseInt(el.dataset.count, 10);
  var suffix = el.dataset.suffix || '';
  var start = 0;
  var step = Math.ceil(target / 60);
  var timer = setInterval(function(){
    start = Math.min(start + step, target);
    el.textContent = start + suffix;
    if(start >= target) clearInterval(timer);
  }, 20);
}

